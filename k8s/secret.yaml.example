# мқҙ нҢҢмқјмқҖ мҳҲмӢңмһ…лӢҲлӢӨ. мӢӨм ң secretмқҖ м•„лһҳ лӘ…л №мңјлЎң мғқм„ұн•ҳм„ёмҡ”:
#
# kubectl create secret generic travel-secrets \
#   --from-env-file=.env
#
# лҳҗлҠ” м§Ғм ‘ мһ‘м„ұ мӢң base64 мқёмҪ”л”© н•„мҡ”:
# echo -n "your-api-key" | base64

apiVersion: v1
kind: Secret
metadata:
  name: travel-secrets
type: Opaque
stringData:
  GROQ_API_KEY: "your-groq-api-key"
  OPENWEATHER_API_KEY: "your-openweather-api-key"
